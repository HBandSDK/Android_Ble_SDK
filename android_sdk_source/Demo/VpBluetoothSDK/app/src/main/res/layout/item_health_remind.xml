<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/date_time_btn_bg"
    android:layout_margin="2dp"
    android:paddingStart="10dp"
    android:paddingTop="8dp"
    android:paddingEnd="10dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/tvHealthRemindName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:text="久坐提醒"
        android:textColor="#000"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvHealthRemindTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:text="时间范围：09:00-18:00"
        android:textColor="#222"
        android:textSize="15sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHealthRemindName" />

    <TextView
        android:id="@+id/tvHealthRemindInterval"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:text="间隔(分钟):"
        android:textColor="#222"
        android:textSize="15sp"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHealthRemindTime" />

    <EditText
        android:id="@+id/etInterval"
        style="@style/ProtocolEditText"
        android:text="30"
        android:inputType="number"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toEndOf="@id/tvHealthRemindInterval"
        app:layout_constraintTop_toTopOf="@id/tvHealthRemindInterval"
        app:layout_constraintBottom_toBottomOf="@id/tvHealthRemindInterval"
        android:layout_width="120dp"
        android:layout_height="34dp"/>


    <com.github.iielse.switchbutton.SwitchView
        android:id="@+id/sv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>