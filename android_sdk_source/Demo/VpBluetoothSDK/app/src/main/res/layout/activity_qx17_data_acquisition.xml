<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="QX17 数据采集流控演示"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/tv_qx17_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="状态: 未知"
        android:textSize="14sp"
        android:paddingBottom="8dp"
        android:textColor="#FF1055D2" />

    <Button
        android:id="@+id/btn_qx17_start"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="开启数据采集" />

    <Button
        android:id="@+id/btn_qx17_stop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="关闭数据采集"
        android:layout_marginTop="4dp" />

    <Button
        android:id="@+id/btn_qx17_continue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="继续数据采集(重传)"
        android:layout_marginTop="4dp" />

    <Button
        android:id="@+id/btn_qx17_clear_log"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="清空日志"
        android:layout_marginTop="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="--- 振动马达控制 ---"
        android:textSize="12sp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <Spinner
            android:id="@+id/spinner_qx17_vibration_mode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <EditText
            android:id="@+id/et_qx17_vibration_duration"
            android:layout_width="70dp"
            android:layout_height="wrap_content"
            android:hint="时长"
            android:inputType="number"
            android:text="0"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginLeft="4dp"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btn_qx17_send_vibration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="发送"
            android:layout_marginLeft="4dp"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="--- 数据日志 ---"
        android:textSize="12sp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp" />

    <ScrollView
        android:id="@+id/scroll_qx17_log"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:background="#F5F5F5">

        <TextView
            android:id="@+id/tv_qx17_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="8dp" />

    </ScrollView>

</LinearLayout>
